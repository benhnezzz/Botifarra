# Copia este archivo a ".env" y completa tus propias claves.
# ".env" está en .gitignore: nunca se sube al repositorio.

# Usadas por .wa (comando checkWhatsApp) para verificar números
NUMVERIFY_KEY=
ABSTRACTAPI_KEY=

# Clave de la API de Groq (gratis, sin tarjeta), usada por .rpgcrearclase y
# .rpgcrearraza para generar contenido nuevo del RPG con IA.
# Consíguela en https://console.groq.com/keys (login con Google)
GROQ_API_KEY=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
# Opcional: modelo a usar (por defecto llama-3.3-70b-versatile)
GROQ_MODEL=

# Alternativa a config.js para definir el owner por variables de entorno
OWNER_NUMBER=
OWNER_LIDS=
PAIRING_NUMBER=
